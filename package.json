{
  "name": "pokedex-electron",
  "version": "1.1.0",
  "description": "A professional Electron Pokédex with retro aesthetics.",
  "type": "module",
  "main": "dist/main/main.cjs",
  "bin": {
    "pokedex-electron": "./dist/main/cli.cjs"
  },
  "files": [
    "dist"
  ],
  "author": "Barış Kısır",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bariskisir/pokedex.git"
  },
  "keywords": [
    "pokemon",
    "pokedex",
    "electron",
    "papi",
    "retro"
  ],
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "vite --configLoader native",
    "clean": "node scripts/clean-dist.cjs",
    "build": "npm run clean && npm run build:renderer && npm run build:main",
    "build:renderer": "vite build --configLoader native",
    "build:main": "tsc -p tsconfig.main.json",
    "preview": "vite preview --configLoader native",
    "prepack": "npm run build"
  },
  "dependencies": {
    "electron": "40.8.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vite": "7.3.2"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "postcss": "8.5.14"
  }
}
